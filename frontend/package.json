{
  "name": "prymal-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:seo": "node scripts/generate-seo-assets.mjs",
    "prebuild": "npm run generate:seo",
    "build": "vite build",
    "prerender": "node scripts/prerender.mjs",
    "postbuild": "npm run prerender",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix && prettier --write src",
    "typecheck": "npm run build",
    "verify": "npm run lint && npm test && npm run build",
    "preview": "vite preview",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 4173",
    "verify-build": "node scripts/verify-build.mjs",
    "avatar:prepare": "node scripts/convert-agent-avatar.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/run-playwright.mjs dev",
    "test:e2e:public": "node scripts/run-playwright.mjs public",
    "test:e2e:dev": "node scripts/run-playwright.mjs dev",
    "test:e2e:auth:check": "node scripts/check-playwright-auth.mjs",
    "test:e2e:auth": "node scripts/run-playwright.mjs auth",
    "test:e2e:headed": "node scripts/run-playwright.mjs dev --headed",
    "test:e2e:ui": "playwright test --ui",
    "perf:budget": "node scripts/check-bundles.mjs"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.6",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "@sentry/react": "^10.55.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-virtual": "^3.13.24",
    "framer-motion": "^12.10.5",
    "gsap": "^3.14.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.26.2",
    "reactflow": "^11.11.4",
    "simple-icons": "^16.19.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.27",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "vite": "^5.4.6",
    "vitest": "^2.1.4"
  },
  "optionalDependencies": {
    "@esbuild/win32-arm64": "^0.21.5",
    "@rollup/rollup-win32-arm64-msvc": "^4.60.4",
    "@rollup/rollup-win32-x64-msvc": "^4.60.3"
  },
  "overrides": {
    "js-cookie": "3.0.7"
  }
}
