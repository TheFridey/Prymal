# Clerk publishable key
# Use the Clerk test/staging key in staging and the live production key in production.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_cnVsaW5nLWVlbC01MC5jbGVyay5hY2NvdW50cy5kZXYk

# Backend origin or full /api base
# Both of these work with the current frontend helper:
# VITE_API_URL=http://localhost:3001
# VITE_API_URL=http://localhost:3001/api
# For staging/production, use the absolute deployed API URL.
VITE_API_URL=http://localhost:3001

# Optional. Get DSN from sentry.io. Leave blank to disable frontend error tracking.
VITE_SENTRY_DSN=
