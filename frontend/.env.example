# Clerk publishable key
# Use the Clerk test/staging key in staging and the live production key in production.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_placeholder

# Backend origin or full /api base
# Both of these work with the current frontend helper:
# VITE_API_URL=http://localhost:3001
# VITE_API_URL=http://localhost:3001/api
# For staging/production, use the absolute deployed API URL.
VITE_API_URL=http://localhost:3001/api
# Optional: always show founding-tier headline prices on /pricing (e.g. static deploys without the API).
# Checkout still enforces eligibility and Stripe founder price IDs on the server.
# VITE_FORCE_FOUNDING_PRICING_UI=true

# Optional. Plausible analytics domain (script is injected only in production builds — not in vite dev).
# VITE_PLAUSIBLE_DOMAIN=prymal.io

# Optional. Get DSN from sentry.io. Leave blank to disable frontend error tracking.
VITE_SENTRY_DSN=

# --- Playwright E2E (`npm run test:e2e`)
# These are loaded by playwright.config.js (Node does not use Vite's env injection).
# Match `VITE_API_URL` unless you point tests at another backend.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173
PLAYWRIGHT_API_URL=http://localhost:3001

# Clerk staging/test accounts (password sign-in). Leave blank to skip authenticated specs.
# Roles map to tests/helpers/auth.js — use distinct accounts where the flow requires it.
PLAYWRIGHT_TEST_USER_EMAIL=
PLAYWRIGHT_TEST_USER_PASSWORD=
PLAYWRIGHT_TEST_STAFF_EMAIL=
PLAYWRIGHT_TEST_STAFF_PASSWORD=
PLAYWRIGHT_TEST_INVITEE_EMAIL=
PLAYWRIGHT_TEST_INVITEE_PASSWORD=
PLAYWRIGHT_TEST_ONBOARDING_EMAIL=
PLAYWRIGHT_TEST_ONBOARDING_PASSWORD=
PLAYWRIGHT_TEST_BILLING_EMAIL=
PLAYWRIGHT_TEST_BILLING_PASSWORD=

# Set true in CI if authenticated Playwright must fail when credentials are missing.
# PLAYWRIGHT_AUTH_REQUIRED=false
