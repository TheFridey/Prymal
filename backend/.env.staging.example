NODE_ENV=staging
PORT=3000
WEB_CONCURRENCY=1
SENTRY_ENVIRONMENT=staging

DATABASE_URL=postgresql://user:password@staging-db-host:5432/prymal

FRONTEND_URL=https://staging.prymal.io
FRONTEND_URLS=https://staging.prymal.io
API_URL=https://staging-api.prymal.io
APP_URL=https://staging.prymal.io
SENTRY_DSN=

CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder
CLERK_WEBHOOK_SECRET=whsec_placeholder

OPENAI_API_KEY=openai_api_key_placeholder
ANTHROPIC_API_KEY=anthropic_api_key_placeholder
GEMINI_API_KEY=gemini_api_key_placeholder

MEDIA_STORAGE_DRIVER=cloudinary
CLOUDINARY_CLOUD_NAME=cloudinary_cloud_name_placeholder
CLOUDINARY_API_KEY=cloudinary_api_key_placeholder
CLOUDINARY_API_SECRET=cloudinary_api_secret_placeholder
CLOUDINARY_FOLDER=prymal-staging
ALLOW_LOCAL_MEDIA_STORAGE_IN_PRODUCTION=false
VIDEO_REFERENCE_ASSET_RETENTION=keep_for_audit
# Required only when more than one backend process is used.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TRIGGER_API_KEY=
TRIGGER_API_URL=https://api.trigger.dev
# Without Trigger.dev, the inline scheduler must run on exactly one backend process.
INLINE_SCHEDULER_ENABLED=true

RESEND_API_KEY=resend_api_key_placeholder
RESEND_FROM_EMAIL=Prymal <ops@example.com>
EMAIL_FROM=Prymal <ops@example.com>
REPLY_TO_EMAIL=hello@example.com
INVITE_EMAIL_REPLY_TO=hello@example.com

