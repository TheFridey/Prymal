{
  "name": "prymal-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "dev:bun": "bun --hot src/index.js",
    "start": "node src/index.js",
    "start:bun": "bun src/index.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix && prettier --write src",
    "typecheck": "npm run lint",
    "verify": "npm run lint && npm test",
    "test": "node scripts/run-tests.mjs",
    "test:ci": "node scripts/run-tests.mjs",
    "env:validate": "node scripts/validate-env.mjs --scope backend --mode production",
    "security:preflight": "node scripts/preflight-production-security.mjs",
    "compliance:evidence": "node scripts/collect-security-evidence.mjs",
    "schema:check": "node scripts/check-schema-drift.mjs",
    "db:verify-local": "node scripts/verify-local-db.mjs",
    "beta:check": "node scripts/beta-readiness-check.mjs",
    "beta:evidence": "node scripts/beta-db-evidence.mjs --section all --limit 10",
    "dev:evidence": "node scripts/dev-evidence.mjs",
    "dev:fixtures": "node scripts/dev-fixtures.mjs",
    "test:workflow:db": "node scripts/run-workflow-db-test.mjs",
    "catalogue:seed": "node scripts/seed-workflow-catalogue.mjs",
    "email:test": "node scripts/send-test-email.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node src/db/migrate.js",
    "clerk:align": "node scripts/clerk-env-align.mjs",
    "staff:set-owner-agency": "node scripts/set-owner-agency.mjs",
    "worker": "node src/queue/worker.js",
    "worker:video": "node src/workers/video-worker.js",
    "migrate": "node scripts/run-migrations.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@google/genai": "^1.25.0",
    "@hono/clerk-auth": "^3.1.1",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.8.0",
    "@scalar/hono-api-reference": "^0.11.6",
    "@sentry/node": "^10.62.0",
    "@sentry/profiling-node": "^10.62.0",
    "@trigger.dev/sdk": "4.4.6",
    "cloudinary": "^2.10.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "mammoth": "^1.8.0",
    "node-cron": "^4.5.0",
    "openai": "^4.57.0",
    "pdf-parse": "^1.1.1",
    "pino": "^10.3.1",
    "playwright": "^1.61.1",
    "postgres": "^3.4.9",
    "stripe": "^16.10.0",
    "svix": "^1.96.1",
    "zod": "^3.23.8"
  },
  "overrides": {
    "@clerk/backend": "2.33.3",
    "@clerk/shared": "3.47.5",
    "@clerk/types": "4.101.23",
    "@xmldom/xmldom": "^0.8.13",
    "brace-expansion": "^5.0.6",
    "protobufjs": "^7.6.0",
    "@protobufjs/codegen": "^2.0.5",
    "@protobufjs/fetch": "^1.1.1",
    "@protobufjs/inquire": "^1.1.2",
    "@protobufjs/utf8": "^1.1.1",
    "ws": "^8.20.1",
    "js-cookie": "3.0.7",
    "systeminformation": "5.31.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.1"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
