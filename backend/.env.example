# Server
PORT=3001
NODE_ENV=development
# Logging — pino log level. info in production, debug in development, trace for deep debugging (never in prod).
LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173
# Optional comma-separated allowlist for local/frontend origins
# FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174
API_URL=http://localhost:3001
# For staging and production, keep FRONTEND_URL and API_URL pointed at the matching environment only.

# Workflow Catalogue
WORKFLOW_CATALOGUE_ENABLED=true
WORKFLOW_CATALOGUE_USER_SUBMISSIONS_ENABLED=true
WORKFLOW_CATALOGUE_PREMIUM_ENABLED=true
WORKFLOW_CATALOGUE_PLATFORM_FEE_BPS=2500
WORKFLOW_CATALOGUE_SEED_USER_ID=prymal-system
# Optional. Get DSN from sentry.io. Leave blank to disable error tracking.
SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
SENTRY_ENVIRONMENT=production
# Set this during CI/CD to the git SHA.
SENTRY_RELEASE=

# Database
# Docker default from ../docker-compose.yml — map is usually host port 5433 → container 5432
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/prymal
# If requests hang ~10s then fail: ensure `docker compose up -d prymal-db` (from repo root) is running,
# credentials match Postgres, and on Windows prefer 127.0.0.1 over `localhost` when Docker Desktop IPv6 causes issues.



# Clerk (same Clerk application keys as frontend VITE_CLERK_PUBLISHABLE_KEY)
CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder
CLERK_WEBHOOK_SECRET=whsec_placeholder
# Regional / custom Clerk API — copy from Clerk Dashboard → API keys if not using defaults.
# CLERK_API_URL=https://api.clerk.com
# CLERK_API_VERSION=2025-02-07

# Model providers
ANTHROPIC_API_KEY=anthropic_api_key_placeholder
OPENAI_API_KEY=openai_api_key_placeholder
# Google Gemini — optional third provider lane (low-cost bulk, fallback chat)
# Get a key at https://aistudio.google.com/apikey  (starts with "AI")
GEMINI_API_KEY=gemini_api_key_placeholder
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_LITE=gemini-2.5-flash-lite
GEMINI_MODEL_PRO=gemini-2.5-pro
# Enable only when you want live grounded-research traffic to prefer Gemini.
GEMINI_GROUNDING_ENABLED=true
# Veo 3.1 Lite video generation
GEMINI_MODEL_VEO=veo-3.1-lite-generate-preview
# Veo 3.1 Standard video generation for higher-fidelity renders
GEMINI_MODEL_VEO_STANDARD=veo-3.1-generate-preview

# Media storage
# development: local is fine
# staging/production: use Cloudinary for generated media and reference images
MEDIA_STORAGE_DRIVER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=prymal
# Allow local media storage in production-like environments only for break-glass debugging.
ALLOW_LOCAL_MEDIA_STORAGE_IN_PRODUCTION=false
# Reference-image retention:
# - delete_after_job for local dev
# - keep_for_audit for closed beta / live-like environments
VIDEO_REFERENCE_ASSET_RETENTION=delete_after_job
MEDIA_ASSET_RETENTION_DAYS=30
FAILED_MEDIA_ASSET_RETENTION_DAYS=7
VIDEO_JOB_TIMEOUT_MS=900000
VIDEO_JOB_POLL_INTERVAL_MS=10000
# Durable video worker. When true, POST /agents/generate-video only reserves credits
# and enqueues the job; the worker (npm run worker:video) drives provider calls.
# Leave unset/false for local dev to fall back to inline processing.
VIDEO_WORKER_ENABLED=false
VIDEO_WORKER_POLL_MS=5000
VIDEO_WORKER_BATCH_SIZE=3
VIDEO_JOB_PROCESSING_TIMEOUT_MS=900000

# Optional model overrides
# Anthropic current family defaults
ANTHROPIC_MODEL_OPUS=claude-opus-4-7
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-6
ANTHROPIC_MODEL_FALLBACK=claude-haiku-4-5
# Explicit lane mappings for the policy router
ANTHROPIC_MODEL_PREMIUM=claude-opus-4-7
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
# OpenAI routed text stack
OPENAI_MODEL_ANALYSIS=gpt-5.5
OPENAI_MODEL_PREMIUM=gpt-5.5
OPENAI_MODEL_ROUTER=gpt-5.4-mini
OPENAI_MODEL_LIGHTWEIGHT=gpt-5.4-nano
# Optional per-org override scaffold
# ORG_MODEL_POLICY_OVERRIDES={"org_uuid":{"policies":{"premium_reasoning":{"provider":"anthropic","model":"claude-opus-4-7"}}}}
ORG_MODEL_POLICY_OVERRIDES=
# OpenAI current audio default
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# Voice TTS output
# Set to true to enable agent voice responses (requires OPENAI_API_KEY)
OPENAI_TTS_ENABLED=false
# Comma-separated plan names that get the HD model (tts-1-hd); others use tts-1
OPENAI_TTS_HD_PLANS=teams,agency
# OpenAI image generation
OPENAI_IMAGE_MODEL=gpt-image-1.5

# Transactional email delivery
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=Prymal <ops@yourdomain.com>
EMAIL_FROM=Prymal <ops@yourdomain.com>
REPLY_TO_EMAIL=hello@yourdomain.com
INVITE_EMAIL_REPLY_TO=hello@yourdomain.com
APP_URL=http://localhost:5173
EMAIL_LOGO_URL=cid:prymal-logo
EMAIL_HERALD_AVATAR_URL=cid:herald-avatar
EMAIL_EMBED_INLINE_ASSETS=true

# WARDEN input-side safety firewall
WARDEN_ENABLED=true
WARDEN_STRICT_MODE=false
WARDEN_MAX_CONTENT_CHARS=500000
WARDEN_MAX_URL_TEXT_CHARS=240000
WARDEN_AUDIT_EXCERPT_CHARS=500
WARDEN_MEDIA_SAFETY_STRICTNESS=standard
WARDEN_MODEL_CLASSIFIER_ENABLED=true
WARDEN_MODEL_CLASSIFIER_MODE=auto
WARDEN_MODEL_CLASSIFIER_MODEL=gpt-5-mini
WARDEN_MODEL_CLASSIFIER_TIMEOUT_MS=3000
WARDEN_MODEL_CLASSIFIER_MAX_CHARS=12000
WARDEN_MODEL_CLASSIFIER_CACHE_TTL_SECONDS=900
WARDEN_MODEL_CLASSIFIER_CACHE_MAX=1000
WARDEN_MODEL_CLASSIFIER_DAILY_CALL_CAP=500
WARDEN_MODEL_CLASSIFIER_DAILY_COST_CAP_USD=5
WARDEN_MODEL_CLASSIFIER_INPUT_TOKEN_PRICE_USD=
WARDEN_MODEL_CLASSIFIER_OUTPUT_TOKEN_PRICE_USD=
WARDEN_OCR_ENABLED=false
WARDEN_OCR_PROVIDER=none
WARDEN_OCR_TIMEOUT_MS=3000
WARDEN_OCR_MAX_IMAGES=4
WARDEN_OCR_CACHE_TTL_SECONDS=900
WARDEN_OCR_CACHE_MAX=500
GOOGLE_VISION_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
TESSERACT_ENABLED=false

# Internal staff admin access
# Legacy blanket allowlists. If used, they grant superadmin access.
STAFF_USER_IDS=user_id_placeholder
STAFF_EMAILS=ops_email_placeholder@example.com
# Preferred tiered staff roles
STAFF_SUPPORT_USER_IDS=
STAFF_SUPPORT_EMAILS=
STAFF_OPS_USER_IDS=
STAFF_OPS_EMAILS=
STAFF_FINANCE_USER_IDS=
STAFF_FINANCE_EMAILS=
STAFF_SUPERADMIN_USER_IDS=
STAFF_SUPERADMIN_EMAILS=
# Optional first-user support cohort. Matching Clerk user IDs are tagged as earlyUser in structured failure logs.
EARLY_USER_IDS=

# Optional per-model cost overrides for LLM trace estimation (JSON object)
# MODEL_COST_OVERRIDES={"openai:gpt-5.4":{"inputPerMillion":2,"outputPerMillion":8}}
MODEL_COST_OVERRIDES=

# ── Rate limiting (optional Redis backend) ────────────────────────────────────
# Without these, rate limiting uses an in-process memory store.
# The memory store is correct for single-process deployments.
# For multi-process or horizontally scaled deployments, rate limits will not be
# shared across instances — each instance enforces its own counters independently.
# To share rate limit state across instances, provision an Upstash Redis database
# at https://upstash.com and paste the REST URL and token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Workflow runtime reliability controls
WORKFLOW_NODE_TIMEOUT_MS=90000
WORKFLOW_RUN_TIMEOUT_MS=900000
WORKFLOW_MAX_ATTEMPTS=3
# Prune fallback for temporary session memory with no explicit expiresAt
MEMORY_SESSION_TTL_HOURS=24
# Workflow-scoped agent_memory TTL (hours) when expires_at is not explicitly provided on write
MEMORY_WORKFLOW_TTL_HOURS=168

# Integrations
GOOGLE_CLIENT_ID=google_client_id_placeholder.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=google_client_secret_placeholder
NOTION_CLIENT_ID=notion_client_id_placeholder
NOTION_CLIENT_SECRET=notion_client_secret_placeholder
SLACK_CLIENT_ID=slack_client_id_placeholder
SLACK_CLIENT_SECRET=slack_client_secret_placeholder
LINKEDIN_CLIENT_ID=77i5yoyriln6av
LINKEDIN_CLIENT_SECRET=WPL_AP1.rnBltJI9E7lpJewF.h3kN7g==
# Optional LinkedIn REST API version override. Default is pinned in backend/src/services/integration-catalog.js.
LINKEDIN_API_VERSION=
MICROSOFT_CLIENT_ID=microsoft_client_id_placeholder
MICROSOFT_CLIENT_SECRET=microsoft_client_secret_placeholder

# Billing
STRIPE_SECRET_KEY=stripe_secret_key_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
# Founding onboarding execution bonus (never scales video or duplicates plan allowances)
FOUNDING_ACCESS_ONBOARDING_EXECUTION_CREDITS=250
STRIPE_PRICE_SOLO=price_xxxx
STRIPE_PRICE_SOLO_QUARTERLY=price_xxxx
STRIPE_PRICE_SOLO_YEARLY=price_xxxx
STRIPE_PRICE_PRO=price_xxxx
STRIPE_PRICE_PRO_QUARTERLY=price_xxxx
STRIPE_PRICE_PRO_YEARLY=price_xxxx
STRIPE_PRICE_TEAMS=price_xxxx
STRIPE_PRICE_TEAMS_QUARTERLY=price_xxxx
STRIPE_PRICE_TEAMS_YEARLY=price_xxxx
STRIPE_PRICE_AGENCY=price_xxxx
STRIPE_PRICE_AGENCY_QUARTERLY=price_xxxx
STRIPE_PRICE_AGENCY_YEARLY=price_xxxx
# Legacy Agency Stripe price IDs — webhook mapping only for grandfathered subscriptions; do not use for NEW checkout — point STRIPE_PRICE_AGENCY_* at the current £299 standard prices instead.
STRIPE_PRICE_AGENCY_LEGACY=
STRIPE_PRICE_AGENCY_LEGACY_QUARTERLY=
STRIPE_PRICE_AGENCY_LEGACY_YEARLY=
# Founding Access Stripe price IDs (≈20% off for the founding window vs list). Configure durations in Stripe; renew at standard catalog prices afterward.
STRIPE_PRICE_FOUNDING_SOLO=price_xxxx
STRIPE_PRICE_FOUNDING_SOLO_QUARTERLY=price_xxxx
STRIPE_PRICE_FOUNDING_SOLO_YEARLY=price_xxxx
STRIPE_PRICE_FOUNDING_PRO=price_xxxx
STRIPE_PRICE_FOUNDING_PRO_QUARTERLY=price_xxxx
STRIPE_PRICE_FOUNDING_PRO_YEARLY=price_xxxx
STRIPE_PRICE_FOUNDING_TEAMS=price_xxxx
STRIPE_PRICE_FOUNDING_TEAMS_QUARTERLY=price_xxxx
STRIPE_PRICE_FOUNDING_TEAMS_YEARLY=price_xxxx
STRIPE_PRICE_FOUNDING_AGENCY=price_xxxx
STRIPE_PRICE_FOUNDING_AGENCY_QUARTERLY=price_xxxx
STRIPE_PRICE_FOUNDING_AGENCY_YEARLY=price_xxxx
# Preferred add-on packs for new checkout
STRIPE_PRICE_EXEC_BOOST_1000=price_xxxx
STRIPE_PRICE_VIDEO_PACK_SMALL=price_xxxx
STRIPE_PRICE_VIDEO_PACK_PRO=price_xxxx
# Legacy add-on pack IDs — keep only for historical webhook compatibility; do not promote in new UI.
STRIPE_PRICE_EXEC_100=price_xxxx
STRIPE_PRICE_EXEC_300=price_xxxx
STRIPE_PRICE_EXEC_700=price_xxxx
STRIPE_PRICE_VIDEO_15=price_xxxx
STRIPE_PRICE_VIDEO_30=price_xxxx
STRIPE_PRICE_VIDEO_100=price_xxxx
# Recurring Stripe price ID for the Teams seat add-on (1 seat unit, billed monthly).
# Create this in the Stripe dashboard as a recurring price on a "Seat add-on" product.
# If absent, the POST /billing/seat-addon endpoint will return 503.
STRIPE_PRICE_SEAT_ADDON=price_xxxx

# Internal cost-protection controls (not user-visible)
# Optional per-plan monthly internal burn caps (GBP), override defaults from billing-catalog:
# BILLING_INTERNAL_CAP_GBP_SOLO=8
# BILLING_INTERNAL_CAP_GBP_PRO=20
# BILLING_INTERNAL_CAP_GBP_TEAMS=45
# BILLING_INTERNAL_CAP_GBP_AGENCY=75
BILLING_COST_GUARD_RATIO=0.7
BILLING_COST_GUARD_USD_TO_GBP=0.79
BILLING_COST_GUARD_DELAY_MS=7500

# Estimated USD threshold on Solo video commits to flag abnormal provider cost (metadata + product event).
# SOLO_VIDEO_SPIKE_WARN_USD=2

# Staff economics: log a warning when total estimated burn / estimated MRR exceeds this ratio (server-side).
# ADMIN_BURN_TO_MRR_RATIO_ALERT=1.2

# WREN escalation dispatch
# Email address to receive escalation alerts from the WREN support agent.
# If absent, WREN will silently skip escalation dispatch and log a warning.
WREN_ESCALATION_EMAIL=support@yourdomain.com
# Minimum refund amount (GBP) to trigger a medium-severity escalation.
# Refund mentions below this value are ignored. Default: 50
WREN_REFUND_THRESHOLD_GBP=50

# Optional workflow scheduling
TRIGGER_API_KEY=trigger_api_key_placeholder
TRIGGER_API_URL=https://api.trigger.dev
# Optional. In live environments without Trigger.dev, enable the inline scheduler on exactly one backend process only.
# INLINE_SCHEDULER_ENABLED=true

# Required for encrypted OAuth token storage
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Validate production envs before deploy with:
# NODE_ENV=production npm run env:validate
ENCRYPTION_KEY=replace_with_64_hex_characters

# Optional, but recommended so OAuth callback state cannot be forged
INTEGRATION_STATE_SECRET=replace_with_long_random_secret_value
