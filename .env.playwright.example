# Default localhost QA Playwright configuration.
# Use Clerk test/local QA users only. Do not place production credentials here.
# `npm run test:e2e:dev` uses local preview + localhost API and skips auth-required suites when creds are absent.
# `npm run test:e2e:auth` and `npm run test:e2e:auth:check` expect the values below to be real local QA credentials.
# After filling this file, run `cd backend && npm run dev:fixtures` once to provision the local QA users and dev DB rows.
# Flip PLAYWRIGHT_AUTH_REQUIRED=true only when you intentionally want strict authenticated smoke outside the helper scripts.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173
PLAYWRIGHT_API_URL=http://127.0.0.1:3001/api
PLAYWRIGHT_MANAGED_WEBSERVER=true

# Normal owner user for the authenticated app shell, chat, workflows, and LORE.
PLAYWRIGHT_TEST_USER_EMAIL=owner.qa@prymal.io
PLAYWRIGHT_TEST_USER_PASSWORD=replace-with-real-password

# Staff user must already be recognised by the backend staff allowlist (for example STAFF_EMAILS / STAFF_* envs).
PLAYWRIGHT_TEST_STAFF_EMAIL=ops@prymal.io
PLAYWRIGHT_TEST_STAFF_PASSWORD=replace-with-real-password

# Invitee account should have no workspace membership before the invite flow runs.
PLAYWRIGHT_TEST_INVITEE_EMAIL=invitee.qa@prymal.io
PLAYWRIGHT_TEST_INVITEE_PASSWORD=replace-with-real-password

# Onboarding account should stay detached from any org so the first-run setup stays testable.
PLAYWRIGHT_TEST_ONBOARDING_EMAIL=onboarding.qa@prymal.io
PLAYWRIGHT_TEST_ONBOARDING_PASSWORD=replace-with-real-password

# Billing account should be a Clerk test user tied to a local QA org with dev-safe billing fixtures.
PLAYWRIGHT_TEST_BILLING_EMAIL=billing.qa@prymal.io
PLAYWRIGHT_TEST_BILLING_PASSWORD=replace-with-real-password

PLAYWRIGHT_AUTH_REQUIRED=false
